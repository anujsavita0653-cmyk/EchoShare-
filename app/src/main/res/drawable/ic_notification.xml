    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Left bar -->
    <path
        android:pathData="M3,9 L3,15"
        android:strokeWidth="2"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />

    <!-- Left-center bar -->
    <path
        android:pathData="M7,5 L7,19"
        android:strokeWidth="2"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />

    <!-- Center bar -->
    <path
        android:pathData="M12,3 L12,21"
        android:strokeWidth="2"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />

    <!-- Right-center bar -->
    <path
        android:pathData="M17,5 L17,19"
        android:strokeWidth="2"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />

    <!-- Right bar -->
    <path
        android:pathData="M21,9 L21,15"
        android:strokeWidth="2"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />
</vector>
